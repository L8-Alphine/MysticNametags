              Anchor: (Width: 520, Height: 32);

              Label #TagRow3Name {
                Text: "Tag Name";
                Anchor: (Height: 18);
                Style: (FontSize: 15, TextColor: #ffffff);
              }

              Label #TagRow3Description {
                Text: "Short description of this tag.";
                Anchor: (Height: 14);
                Style: (FontSize: 12, TextColor: #94a3b8);
              }
            }

            Group { FlexWeight: 1; }

            $C.@SmallSecondaryTextButton #TagRow3Button {
              @Anchor = (Width: 130, Height: 22);
              Text: "Equip";
            }
          }

          // Row 4
          Group {
            LayoutMode: Left;
            Anchor: (Height: 42);
            Padding: (Left: 12, Right: 12, Bottom: 4);
            Background: #020617(0.86);

            Group {
              LayoutMode: Top;
              Anchor: (Width: 520, Height: 32);

              Label #TagRow4Name {
                Text: "Tag Name";
                Anchor: (Height: 18);
                Style: (FontSize: 15, TextColor: #ffffff);
              }

              Label #TagRow4Description {
                Text: "Short description of this tag.";
                Anchor: (Height: 14);
                Style: (FontSize: 12, TextColor: #94a3b8);
              }
            }

            Group { FlexWeight: 1; }

            $C.@SmallSecondaryTextButton #TagRow4Button {
              @Anchor = (Width: 130, Height: 22);
              Text: "Equip";
            }
          }

          // Row 5
          Group {
            LayoutMode: Left;
            Anchor: (Height: 42);
            Padding: (Left: 12, Right: 12, Bottom: 4);
            Background: #020617(0.86);

            Group {
              LayoutMode: Top;
              Anchor: (Width: 520, Height: 32);

              Label #TagRow5Name {
                Text: "Tag Name";
                Anchor: (Height: 18);
                Style: (FontSize: 15, TextColor: #ffffff);
              }

              Label #TagRow5Description {
                Text: "Short description of this tag.";
                Anchor: (Height: 14);
                Style: (FontSize: 12, TextColor: #94a3b8);
              }
            }

            Group { FlexWeight: 1; }

            $C.@SmallSecondaryTextButton #TagRow5Button {
              @Anchor = (Width: 130, Height: 22);
              Text: "Equip";
            }
          }

          // Row 6
          Group {
            LayoutMode: Left;
            Anchor: (Height: 42);
            Padding: (Left: 12, Right: 12, Bottom: 4);
            Background: #020617(0.86);

            Group {
              LayoutMode: Top;
              Anchor: (Width: 520, Height: 32);

              Label #TagRow6Name {
                Text: "Tag Name";
                Anchor: (Height: 18);
                Style: (FontSize: 15, TextColor: #ffffff);
              }

              Label #TagRow6Description {
                Text: "Short description of this tag.";
                Anchor: (Height: 14);
                Style: (FontSize: 12, TextColor: #94a3b8);
              }
            }

            Group { FlexWeight: 1; }

            $C.@SmallSecondaryTextButton #TagRow6Button {
              @Anchor = (Width: 130, Height: 22);
              Text: "Equip";
            }
          }

          // Row 7
          Group {
            LayoutMode: Left;
            Anchor: (Height: 42);
            Padding: (Left: 12, Right: 12, Bottom: 4);
            Background: #020617(0.86);

            Group {
              LayoutMode: Top;
              Anchor: (Width: 520, Height: 32);

              Label #TagRow7Name {
                Text: "Tag Name";
                Anchor: (Height: 18);
                Style: (FontSize: 15, TextColor: #ffffff);
              }

              Label #TagRow7Description {
                Text: "Short description of this tag.";
                Anchor: (Height: 14);
                Style: (FontSize: 12, TextColor: #94a3b8);
              }
            }

            Group { FlexWeight: 1; }

            $C.@SmallSecondaryTextButton #TagRow7Button {
              @Anchor = (Width: 130, Height: 22);
              Text: "Equip";
            }
          }

          // Row 8
          Group {
            LayoutMode: Left;
            Anchor: (Height: 42);
            Padding: (Left: 12, Right: 12, Bottom: 4);
            Background: #020617(0.86);

            Group {
              LayoutMode: Top;
              Anchor: (Width: 520, Height: 32);

              Label #TagRow8Name {
                Text: "Tag Name";
                Anchor: (Height: 18);
                Style: (FontSize: 15, TextColor: #ffffff);
              }

              Label #TagRow8Description {
                Text: "Short description of this tag.";
                Anchor: (Height: 14);
                Style: (FontSize: 12, TextColor: #94a3b8);
              }
            }

            Group { FlexWeight: 1; }

            $C.@SmallSecondaryTextButton #TagRow8Button {
              @Anchor = (Width: 130, Height: 22);
              Text: "Equip";
            }
          }

          // Row 9
          Group {
            LayoutMode: Left;
            Anchor: (Height: 42);
            Padding: (Left: 12, Right: 12, Bottom: 4);
            Background: #020617(0.86);

            Group {
              LayoutMode: Top;
              Anchor: (Width: 520, Height: 32);

              Label #TagRow9Name {
                Text: "Tag Name";
                Anchor: (Height: 18);
                Style: (FontSize: 15, TextColor: #ffffff);
              }

              Label #TagRow9Description {
                Text: "Short description of this tag.";
                Anchor: (Height: 14);
                Style: (FontSize: 12, TextColor: #94a3b8);
              }
            }

            Group { FlexWeight: 1; }

            $C.@SmallSecondaryTextButton #TagRow9Button {
              @Anchor = (Width: 130, Height: 22);
              Text: "Equip";
            }
          }
        }

        Group { Anchor: (Height: 6); }

        // Page controls
        Group #PageControls {
          LayoutMode: Left;
          Anchor: (Height: 24);

          $C.@SmallSecondaryTextButton #PrevPageButton {
            @Anchor = (Width: 110, Height: 22);
            Text: "Prev";
          }

          Group { FlexWeight: 1; }

          Label #PageLabel {
            Text: "Page 1/1";
            Anchor: (Width: 220, Height: 20);
            Style: (FontSize: 12, TextColor: #96a9be, HorizontalAlignment: Center);
          }

          Group { FlexWeight: 1; }

          $C.@SmallSecondaryTextButton #NextPageButton {
            @Anchor = (Width: 110, Height: 22);
            Text: "Next";
          }
        }

        Group { Anchor: (Height: 16); }

        // Footer
        Group {
          LayoutMode: Left;
          Anchor: (Height: 26);

          Label {
            Text: "Click a tag to equip or unequip it.";
            Anchor: (Height: 20);
            Style: (FontSize: 12, TextColor: #64748b);
          }

          Group { FlexWeight: 1; }

          $C.@SmallSecondaryTextButton #BottomCloseButton {
            @Anchor = (Width: 110, Height: 26);
            Text: "CLOSE";
          }
        }
      }
    }
  }
}